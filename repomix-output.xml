   */
  description: string;

  /**
   * Current number of attendees.
   */
  attendeeCount: number;

  /**
   * Maximum number of attendees allowed.
   */
  maxAttendees: number;
};

export type EventCardProps = EventCardLoadingProps | EventCardLoadedProps;
