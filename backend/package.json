{
  "name": "prisma-rest-api",
  "version": "1.0.0",
  "description": "Rest API in TS using Prisma",
  "type": "module",
  "main": "dist/src/index.js",
  "keywords": [],
  "author": "ReDi School",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:ReDI-School/S26-Full-Stack-Circle.git"
  },
  "scripts": {
    "dev": "prisma generate && tsx --require=dotenv/config --watch src/index.ts",
    "build": "prisma generate && tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "lint": "eslint src/ prisma/seed.ts",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/cors": "^2.8.19",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "prisma": "^7.5.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.57.2"
  }
}
